    {
      "id": "scene_02_sound_in_the_dark",
      "title": "The Sound in the Dark",
      "start": 18.0,
      "end": 42.0,
      "camera": {
        "shot": "medium_side_view",
        "movement": "locked"
      },
      "events": [
        {
          "type": "look_at",
          "start": 18.2,
          "end": 19.0,
          "source": "fire",
          "target": "stone"
        },
        {
          "type": "look_forward",
          "start": 18.5,
          "end": 19.5,
          "character": "crystal"
        },
        {
          "type": "look_down",
          "start": 18.6,
          "end": 19.4,
          "character": "earth"
        },
        {
          "type": "dialogue",
          "start": 19.0,
          "end": 22.0,
          "speaker": "fire",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "Did you hear that? Something moved ahead of us."
        },
        {
          "type": "dialogue",
          "start": 22.5,
          "end": 27.0,
          "speaker": "stone",
          "target": "fire",
          "placement": "bottom_screen",
          "text": "I heard the mountain answer. That does not mean it is speaking to us."
        },
        {
          "type": "dialogue",
          "start": 27.8,
          "end": 30.5,
          "speaker": "crystal",
          "target": "all",
          "placement": "bottom_screen",
          "text": "No. Someone opened a path. Recently."
        },
        {
          "type": "dialogue",
          "start": 32.0,
          "end": 33.8,
          "speaker": "earth",
          "target": "crystal",
          "placement": "bottom_screen",
          "text": "You can feel that?"
        },
        {
          "type": "dialogue",
          "start": 34.2,
          "end": 37.2,
          "speaker": "crystal",
          "target": "earth",
          "placement": "bottom_screen",
          "text": "The crystals still carry the touch."
        },
        {
          "type": "state_change",
          "start": 18.0,
          "end": 42.0,
          "characters": [
            "stone",
            "fire",
            "crystal",
            "earth"
          ],
          "state": "idle"
        }
      ]
    },
    {
