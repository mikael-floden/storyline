        "movement": "subtle_drift_right"
      },
      "events": [
        {
          "type": "look_forward",
          "start": 42.0,
          "end": 43.0,
          "character": "stone"
        },
        {
          "type": "micro_step",
          "start": 43.0,
          "end": 43.8,
          "character": "fire",
          "direction": "right",
          "distance_px": 16
        },
        {
          "type": "gesture",
          "start": 44.0,
          "end": 45.5,
          "character": "earth",
          "name": "hand_to_ground"
        },
        {
          "type": "look_forward",
          "start": 45.0,
          "end": 46.0,
          "character": "crystal"
        },
        {
          "type": "dialogue",
          "start": 46.0,
          "end": 49.0,
          "speaker": "earth",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "The road is stable. We can cross."
        },
        {
          "type": "dialogue",
          "start": 49.6,
          "end": 52.0,
          "speaker": "fire",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "Then stop listening to rocks and move."
        },
        {
          "type": "dialogue",
          "start": 52.6,
          "end": 56.0,
          "speaker": "stone",
          "target": "fire",
          "placement": "bottom_screen",
          "text": "I am listening to the silence between them."
        },
        {
          "type": "pause",
          "start": 56.0,
          "end": 57.0
        },
        {
          "type": "dialogue",
          "start": 57.0,
          "end": 59.0,
          "speaker": "stone",
          "target": "all",
          "placement": "bottom_screen",
          "text": "We continue. Stay close."
        },
        {
          "type": "move",
          "start": 57.0,
          "end": 65.0,
          "direction": "right",
          "characters": [
            "stone",
            "fire",
            "crystal",
            "earth"
          ],
          "speed_profile": {
            "stone": 0.92,
            "fire": 1.07,
            "crystal": 0.97,
            "earth": 0.9
          },
          "distance_px": 540
        }
      ]
    },
