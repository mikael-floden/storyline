          "speaker": "crystal",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "This is the place from the memory shards."
        },
        {
          "type": "dialogue",
          "start": 100.6,
          "end": 102.4,
          "speaker": "stone",
          "target": "crystal",
          "placement": "bottom_screen",
          "text": "Tell me what you see."
        },
        {
          "type": "dialogue",
          "start": 103.0,
          "end": 106.0,
          "speaker": "crystal",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "A gate. A fall. A promise unfinished."
        },
        {
          "type": "dialogue",
          "start": 106.8,
          "end": 108.8,
          "speaker": "fire",
          "target": "all",
          "placement": "bottom_screen",
          "text": "I see a doorway. We open it."
        },
        {
          "type": "dialogue",
          "start": 109.5,
          "end": 111.4,
          "speaker": "earth",
          "target": "fire",
          "placement": "bottom_screen",
          "text": "Or it opens us."
        },
        {
          "type": "pause",
          "start": 111.4,
          "end": 113.4
        },
        {
          "type": "dialogue",
          "start": 113.4,
          "end": 115.0,
          "speaker": "crystal",
          "target": "all",
          "placement": "bottom_screen",
          "text": "We are not the first to come here."
        }
      ]
    },
