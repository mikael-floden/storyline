        {
          "type": "caption",
          "start": 91.0,
          "end": 96.0,
          "speaker": "narrator",
          "placement": "bottom_screen",
          "text": "They had reached the First Marker, where the old road divided the faithful from the lost."
        },
        {
          "type": "micro_step",
