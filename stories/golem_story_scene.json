        {
          "type": "dialogue",
          "start": 121.8,
          "end": 124.6,
          "speaker": "stone",
          "target": "fire",
          "placement": "bottom_screen",
          "text": "For the choice that made us."
        },
        {
          "type": "pause",
          "start": 124.6,
          "end": 125.6
        },
        {
          "type": "dialogue",
          "start": 125.6,
          "end": 127.4,
          "speaker": "earth",
          "target": "stone",
          "placement": "bottom_screen",
          "text": "And if the choice is waiting?"
        },
        {
          "type": "dialogue",
          "start": 127.9,
          "end": 130.0,
          "speaker": "stone",
          "target": "earth",
          "placement": "bottom_screen",
          "text": "Then we answer it together."
        }
      ]
